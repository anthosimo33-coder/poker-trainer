    "screenshots:s4b": "tsx scripts/screenshots-s4b.ts",
    "screenshots:s5a": "tsx scripts/screenshots-s5a.ts",
    "screenshots:s5b": "tsx scripts/screenshots-s5b.ts",
    "screenshots:s5c": "tsx scripts/screenshots-s5c.ts",
    "screenshots:s5d": "tsx scripts/screenshots-s5d.ts",
    "seed:lessons": "tsx scripts/seed-lessons.ts"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
